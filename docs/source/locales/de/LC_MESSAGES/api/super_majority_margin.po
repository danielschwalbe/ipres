#: ../../source/api/super_majority_margin.rst:2
msgid "Super Majority Margin"
msgstr ""

#: ipres.super_majority_margin:1 of
msgid "Simple data class for specifying super majority margin."
msgstr "Einfache Datenklasse zur Angabe der Supermehrheitsschwelle."

#: ipres.super_majority_margin.MarginUnit:1 of
msgid "Unit for specifying the super majority margin."
msgstr "Einheit zur Angabe der Supermehrheitsschwelle."

#: ipres.super_majority_margin.SuperMajorityMargin:1 of
msgid "Specifies the margin for a super majority, either in percent or seats."
msgstr "Legt die Schwelle für eine Supermehrheit fest, entweder in Prozent oder in Sitzen."

#: ipres.super_majority_margin.SuperMajorityMargin:3 of
msgid "The super majority is calculated as 50% + margin."
msgstr "Die Supermehrheit ergibt sich aus 50 % + Schwelle."

#: ipres.super_majority_margin.SuperMajorityMargin:6 of
msgid "Examples"
msgstr "Beispiele"

#: ipres.super_majority_margin.SuperMajorityMargin:7 of
msgid ""
"SuperMajorityMargin(5, MarginUnit.PERCENT)  # 55% majority "
"SuperMajorityMargin(10, MarginUnit.SEATS)   # 50% + 10 seats"
msgstr ""
"SuperMajorityMargin(5, MarginUnit.PERCENT)  # 55 % Mehrheit "
"SuperMajorityMargin(10, MarginUnit.SEATS)   # 50 % + 10 Sitze"

#: ipres.super_majority_margin.SuperMajorityMargin of
msgid "Parameters"
msgstr "Parameter"
