#: ipres.election_config.QuotaCorrectionStrategy:1 of
msgid "Enumeration of strategies for correcting party quotas."
msgstr ""

#: ipres.election_config.QuotaCorrectionStrategy:3 of
msgid ""
"When calculating party quotas as seats//2, integer division loses one "
"quota for each party with odd seat count. This creates a deficit: "
"sum(seats[i]//2) < sum(seats)//2"
msgstr ""

#: ipres.election_config.QuotaCorrectionStrategy:7 of
msgid ""
"These strategies determine which parties with odd seats receive +1 to "
"their quota to ensure: sum(quotas) == number_of_constituencies"
msgstr ""

#: ipres.election_config.QuotaCorrectionStrategy:10 of
msgid "FAVOR_SMALL_PARTIES: Prioritize smallest parties (by seat count)"
msgstr ""

#: ipres.election_config.QuotaCorrectionStrategy:11 of
msgid "FAVOR_LARGE_PARTIES: Prioritize largest parties (by seat count)"
msgstr ""

#: ipres.election_config.QuotaCorrectionStrategy:12 of
msgid "PROPORTIONAL: Weighted random, probability proportional to seat count"
msgstr ""

#: ipres.election_config.QuotaCorrectionStrategy:13 of
msgid ""
"PROPORTIONAL_REVERSED: Weighted random, probabilities reversed (small "
"parties favored)"
msgstr ""

#: ipres.election_config.QuotaCorrectionStrategy:14 of
msgid "RANDOM: Uniform random selection among parties with odd seats"
msgstr ""

#: ipres.election_config.QuotaCorrectionStrategy:15 of
msgid "NEGOTIATED: External callback determines which parties receive +1"
msgstr ""

#: ipres.election_config.SeatDistributionMethod:1 of
msgid "Enumeration of seat distribution methods for proportional representation."
msgstr ""

#: ipres.election_config.SeatDistributionMethod:3 of
msgid "SAINTE_LAGUE: Sainte-Laguë/Schepers method (used by German Bundestag)"
msgstr ""

#: ipres.election_config.SeatDistributionMethod:4 of
msgid "D_HONDT: D'Hondt method (used in many European countries)"
msgstr ""

#: ipres.election_config.SeatDistributionMethod:5 of
msgid "HARE_NIEMEYER: Hare-Niemeyer method (largest remainder method)"
msgstr ""

